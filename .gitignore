# Build artifacts of vendored deps — regenerated locally, NOT committed.
# The preflate-rs staticlib (158 MB Rust target) and the kanzi .a's are built
# with -march=native; committing them re-introduces the AVX-512 SIGILL footgun
# on other CPUs. See source/vendor/*/BUILD.md / Makefile comments to rebuild.
source/vendor/preflate-rs/lib/
source/vendor/preflate-rs/target/
source/vendor/kanzi-cpp/build/
source/vendor/kanzi-cpp/build_win/

# Release binaries — attached to GitHub Releases as assets, not tracked in-tree.
source/packPNG-linux-*
source/packPNG-windows-*

# libpackPNG static libraries — fat archives built by `make lib` / `make lib-win`
# (-march=native on Linux); regenerate locally. The public header packpng.h IS tracked.
source/libpackpng.a
source/libpackpng-win.a
source/libpackpng.so
source/packpng.dll
source/libpackpng.dll.a
source/TNCP/target/

